{
  "name": "pangasa-boutique-locator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build/build-index.mjs",
    "test": "node --test",
    "serve": "node --watch-path=web -e \"import('node:http').then(({default:http})=>http.createServer((q,s)=>{import('node:fs').then(fs=>{let p=q.url==='/'?'/index.html':q.url.split('?')[0];try{const b=fs.readFileSync('web'+p);s.writeHead(200);s.end(b)}catch{s.writeHead(404);s.end()}})}).listen(4321,()=>console.log('http://localhost:4321')))\""
  }
}
